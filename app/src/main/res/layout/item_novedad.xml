<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_home"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvFechaNovedad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/texto_font"
        android:text="19/06/2026"
        android:textColor="@color/texto_celeste_card"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloNovedad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/titulo_font"
        android:text="¡Título del Anuncio!"
        android:textColor="@color/texto_dorado_card"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFechaNovedad" />

    <TextView
        android:id="@+id/tvContenidoNovedad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/texto_font"
        android:text="Descripción detallada de lo que pasó en el castillo..."
        android:textColor="@color/pergamino"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloNovedad" />

</androidx.constraintlayout.widget.ConstraintLayout>