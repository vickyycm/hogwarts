<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_hogwarts"
    tools:context=".ui.home.Home">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/titulo_font"
                android:gravity="center"
                android:text="Bienvenido, Mago"
                android:textColor="@color/texto_celeste_card"
                android:textSize="28sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.016" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardTalleres"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_card_home"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBienvenida"
                app:layout_constraintVertical_bias="0.0">

                <TextView
                    android:id="@+id/tvTituloTalleres"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/titulo_font"
                    android:gravity="center"
                    android:text="TALLERES DE MAGOS"
                    android:textColor="@color/texto_dorado_card"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvDescTalleres"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/texto_font"
                    android:gravity="center"
                    android:text="Anotate a las clases dictadas por los magos de Hogwarts."
                    android:textColor="@color/texto_celeste_card"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTituloTalleres" />

                <Button
                    android:id="@+id/btnTalleres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/dorado"
                    android:fontFamily="@font/titulo_font"
                    android:text="Entrar"
                    android:textColor="@color/azul_medianoche"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDescTalleres" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardHechizos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_home"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardTalleres"
                app:layout_constraintVertical_bias="0.0">

                <TextView
                    android:id="@+id/tvTituloHechizos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/titulo_font"
                    android:gravity="center"
                    android:text="CUADERNO DE HECHIZOS"
                    android:textColor="@color/texto_dorado_card"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvDescHechizos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/texto_font"
                    android:gravity="center"
                    android:text="Anotá tus hechizos y pociones, y consultalos cuando quieras."
                    android:textColor="@color/texto_celeste_card"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTituloHechizos" />

                <Button
                    android:id="@+id/btnHechizos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/burdeos"
                    android:fontFamily="@font/titulo_font"
                    android:text="Entrar"
                    android:textColor="@color/pergamino_claro"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDescHechizos" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardForo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_home"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toBottomOf="@id/cardHechizos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvTituloForo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="FORO DE NOVEDADES"
                    android:textColor="@color/texto_dorado_card"
                    android:textSize="22sp"
                    android:fontFamily="@font/titulo_font"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvDescForo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Enterate de las últimas novedades del castillo."
                    android:textColor="@color/texto_celeste_card"
                    android:textSize="18sp"
                    android:fontFamily="@font/texto_font"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/tvTituloForo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="6dp"
                    android:layout_marginHorizontal="8dp" />

                <Button
                    android:id="@+id/btnForo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrar"
                    android:textColor="@color/azul_medianoche"
                    android:backgroundTint="@color/dorado"
                    android:fontFamily="@font/titulo_font"
                    app:layout_constraintTop_toBottomOf="@id/tvDescForo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="14dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>