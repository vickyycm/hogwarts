<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_hechizos"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvNombreHechizo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/titulo_font"
        android:text="Expecto Patronum"
        android:textColor="@color/texto_dorado_card"
        android:textSize="18sp"
        app:layout_constraintEnd_toStartOf="@id/btnEditarHechizo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDescHechizo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/texto_font"
        android:text="Genera un guardián de luz protector contra Dementores."
        android:textColor="@color/dorado_claro"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/btnEditarHechizo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNombreHechizo" />

    <ImageButton
        android:id="@+id/btnEditarHechizo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Editar Hechizo"
        android:src="@android:drawable/ic_menu_edit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnEliminarHechizo"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/dorado" />

    <ImageButton
        android:id="@+id/btnEliminarHechizo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Eliminar Hechizo"
        android:src="@android:drawable/ic_menu_delete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/dorado" />

</androidx.constraintlayout.widget.ConstraintLayout>